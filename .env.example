# Copy this file to `.env` for host-machine runs, or use:
# APP_ENV_FILE=.env.dev for Docker-based runs.

# Host machine example:
DATABASE_URL=postgresql+psycopg://wearwise:wearwise_pw@localhost:5433/wearwise_db

POSTGRES_USER=wearwise
POSTGRES_PASSWORD=wearwise_pw
POSTGRES_DB=wearwise_db
DB_HOST=localhost
DB_PORT=5433

API_PORT=8000
WEB_PORT=3000

JWT_SECRET=replace-with-a-long-random-secret
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_REGION=us-east-1
AWS_BUCKET_NAME=replace-me
